# ==============================
# PETCONNECT BACKEND - Variables de entorno
# Copiá este archivo como .env y completá los valores
# ==============================

# Servidor
PORT=3000
NODE_ENV=development

# MongoDB (obtené tu string en mongodb.com/atlas — gratis)
MONGODB_URI=mongodb+srv://USUARIO:PASSWORD@cluster0.xxxxx.mongodb.net/petconnect

# JWT Secret (cambialo por una cadena larga y aleatoria)
JWT_SECRET=cambia_esto_por_algo_muy_secreto_y_largo_2026
JWT_EXPIRES_IN=7d

# Anthropic - Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Mercado Pago
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxx
MP_PUBLIC_KEY=APP_USR-xxxxxxxxxxxxxxxx

# URL del frontend (para CORS)
FRONTEND_URL=https://tuusuario.github.io
